# =====================================================
# Evolution API — variáveis para `docker compose up` na VPS
# =====================================================
# Copie para `.env` na VPS (mesmo diretório do docker-compose.yml)
# e preencha com valores reais. NUNCA commite o `.env`.

# Chave secreta usada para autenticar requisições HTTP à Evolution.
# Gere com `openssl rand -hex 32`. O MESMO valor entra em Vercel:
#   - EVOLUTION_API_KEY
EVOLUTION_API_KEY=

# Senha do Postgres usado pela própria Evolution (interno ao compose).
POSTGRES_PASSWORD=

# URL pública do webhook que a Evolution chama quando há mensagens.
# Em produção: https://sistema-oficina-pedrored.vercel.app/api/whatsapp/webhook
WEBHOOK_GLOBAL_URL=
