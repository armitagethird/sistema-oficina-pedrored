# =====================================================
# Template para .env.local — Sistema PedroRed (Sprint 0)
# =====================================================
#
# COMO USAR:
#   1. Copie este arquivo para `.env.local` (na raiz do projeto)
#        Windows PowerShell: Copy-Item .env.local.template .env.local
#   2. Preencha cada valor abaixo.
#   3. Reinicie `pnpm dev` se já estiver rodando.
#
# IMPORTANTE: Nunca commite `.env.local`. Já está no .gitignore.
# Este `.env.local.template` PODE ser commitado (sem valores reais).

# -----------------------------------------------------
# Supabase — obtenha em: https://supabase.com/dashboard/project/<ref>/settings/api
# -----------------------------------------------------

# URL completa do projeto. Ex: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — chave anônima, exposta no client.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — APENAS servidor. Nunca expor no client.
SUPABASE_SERVICE_ROLE_KEY=

# Project ref — string curta da URL do dashboard (entre /project/ e /settings).
# Ex: se URL é https://supabase.com/dashboard/project/abcdefghijklmnop/...
#     então SUPABASE_PROJECT_REF=abcdefghijklmnop
SUPABASE_PROJECT_REF=

