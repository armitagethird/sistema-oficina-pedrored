# =====================================================
# Template para .env.local — Sistema PedroRed (Sprint 0)
# =====================================================
#
# COMO USAR:
#   1. COPIE este arquivo para `.env.local` (nome SEM ".template"):
#        Copy-Item .env.local.template .env.local
#   2. Preencha cada valor SOMENTE no `.env.local`, NUNCA neste template.
#   3. Reinicie `pnpm dev` se já estiver rodando.
#
# IMPORTANTE:
#   - `.env.local` está no .gitignore (segredos seguros).
#   - `.env.local.template` ESTÁ versionado (não bate em .env*.local).
#     Mantenha-o com placeholders vazios. NUNCA cole keys aqui.

# -----------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/<ref>/settings/api
# -----------------------------------------------------

# URL completa do projeto. Ex: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — chave anônima, exposta no client.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — APENAS servidor. Nunca expor no client.
SUPABASE_SERVICE_ROLE_KEY=

# Project ref — string curta da URL do dashboard (entre /project/ e /settings).
SUPABASE_PROJECT_REF=

# -----------------------------------------------------
# Cron (Sprint 2)
# -----------------------------------------------------

# Bearer secret usado para autenticar chamadas do Vercel Cron em /api/cron/*.
# Gere um valor forte (ex: `openssl rand -hex 32`). O MESMO valor precisa estar em
# Vercel → Project Settings → Environment Variables (Production + Preview).
CRON_SECRET=

# -----------------------------------------------------
# Sprint 5 (Evolution / WhatsApp)
# -----------------------------------------------------

# URL pública da instância Evolution self-hosted (VPS).
# Ex: https://wa.pedrored.com.br
EVOLUTION_API_URL=

# API key gerada na config da Evolution (também usada no header `apikey`).
EVOLUTION_API_KEY=

# Nome da instância criada na Evolution. Default sugerido: pedrored
EVOLUTION_INSTANCE_NAME=

# Secret opcional que a Evolution deve enviar no header `apikey` ao chamar
# nosso webhook /api/whatsapp/webhook. Se vazio, o webhook aceita sem auth
# (útil em dev). Em produção, preencha o mesmo valor configurado na Evolution.
WHATSAPP_WEBHOOK_SECRET=

# -----------------------------------------------------
# Sprint 6 — PedroRed Store
# -----------------------------------------------------

# Domínio público da loja. Defina quando tiver domínio próprio.
# Sem definir, robots/sitemap apontam para sistema-oficina-pedrored.vercel.app.
NEXT_PUBLIC_SITE_URL=

# Chave PIX do beneficiário (CPF/CNPJ/email/telefone do Pedro).
# Os 3 valores juntos formam o PIX BR Code estático no checkout.
# Placeholders abaixo geram QR sintático válido em dev, mas o pagamento real
# só funciona quando Pedro plugar os valores reais.
PIX_CHAVE=
PIX_NOME_BENEFICIARIO=
PIX_CIDADE=

# Channel ID do canal do YouTube do Pedro (formato UCxxxxxxxxxxxxxxxxxxxxxx).
# Usado pra puxar 3 vídeos mais recentes via RSS público (sem API key, cache 1h).
# Como descobrir: youtube.com/@PEDROredtsi → ver-código-fonte → buscar "channelId".
# Vazio = seção "Pedro no YouTube" não renderiza na home (fallback gracioso).
# Default já é o canal do Pedro; mantém aqui se quiser override por ambiente.
YT_CHANNEL_ID=UCwLMc5ERhoaghTLQ0aH7buA

